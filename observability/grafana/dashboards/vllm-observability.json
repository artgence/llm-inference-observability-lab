{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Completed Request Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(vllm:request_success_total{model_name=~\"$model_name\"}[$__rate_interval]))", "legendFormat": "requests/sec", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Active and Queued Requests",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(vllm:num_requests_running{model_name=~\"$model_name\"})", "legendFormat": "running", "refId": "A"},
        {"expr": "sum(vllm:num_requests_waiting{model_name=~\"$model_name\"})", "legendFormat": "waiting", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "TTFT Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model_name\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model_name\"}[$__rate_interval])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model_name\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "TPOT / Inter-Token Latency",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model_name\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model_name\"}[$__rate_interval])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model_name\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "End-to-End Latency p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model_name\"}[$__rate_interval])))", "legendFormat": "p95", "refId": "A"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model_name\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Token Throughput",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(vllm:prompt_tokens_total{model_name=~\"$model_name\"}[$__rate_interval]))", "legendFormat": "prompt tokens/sec", "refId": "A"},
        {"expr": "sum(rate(vllm:generation_tokens_total{model_name=~\"$model_name\"}[$__rate_interval]))", "legendFormat": "generation tokens/sec", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "KV Cache Usage",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(vllm:kv_cache_usage_perc{model_name=~\"$model_name\"}) * 100", "legendFormat": "KV cache", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GPU Memory Used",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "DCGM_FI_DEV_FB_USED * 1024 * 1024", "legendFormat": "GPU {{gpu}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "GPU Utilization",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "GPU {{gpu}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Benchmark Failure Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(llm_benchmark_requests_completed_total{run_id=~\"$run_id\",outcome=\"error\"}[$__rate_interval])) / clamp_min(sum(rate(llm_benchmark_requests_completed_total{run_id=~\"$run_id\"}[$__rate_interval])), 1e-9)", "legendFormat": "failure rate", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Client In-Flight Requests",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (workload) (llm_benchmark_inflight_requests{run_id=~\"$run_id\"})", "legendFormat": "{{workload}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Timeout Count",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(llm_benchmark_errors_total{run_id=~\"$run_id\",error_type=\"timeout\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 13,
      "type": "stat",
      "title": "OOM Count",
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(llm_benchmark_errors_total{run_id=~\"$run_id\",error_type=\"oom\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto", "textMode": "auto"}
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Rejected Count",
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(llm_benchmark_errors_total{run_id=~\"$run_id\",error_type=\"rejected\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto", "textMode": "auto"}
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["vllm", "observability", "month3"],
  "templating": {
    "list": [
      {"name": "model_name", "label": "Model", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": {"query": "label_values(vllm:num_requests_running, model_name)", "refId": "PrometheusVariableQueryEditor-VariableQuery"}, "includeAll": true, "allValue": ".*", "refresh": 1},
      {"name": "run_id", "label": "Benchmark Run", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": {"query": "label_values(llm_benchmark_run_info, run_id)", "refId": "PrometheusVariableQueryEditor-VariableQuery"}, "includeAll": true, "allValue": ".*", "refresh": 1}
    ]
  },
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "vLLM Inference Observability Lab",
  "uid": "vllm-observability-lab",
  "version": 1
}
