{
  "description": "Month 4 continuous-batching capacity sweep across client concurrency.",
  "model": "neuralmagic/Meta-Llama-3.1-8B-Instruct-FP8",
  "base_url": "http://localhost:8000",
  "api_key": "EMPTY",
  "max_model_len": 16384,
  "runs": [
    {
      "name": "m4_batching_c1_p512_o128",
