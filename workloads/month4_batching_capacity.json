      "prompt_tokens": 512,
      "max_tokens": 128,
      "output_tokens_target": 128,
      "temperature": 0.0,
      "timeout_seconds": 240
    },
    {
      "name": "m4_batching_c8_p512_o128",
      "analysis_group": "batching_capacity",
      "request_count": 80,
      "concurrency": 8,
