      "max_tokens": 128,
      "output_tokens_target": 128,
      "temperature": 0.0,
      "timeout_seconds": 240
    },
    {
      "name": "m4_batching_c32_p512_o128",
      "analysis_group": "batching_capacity",
      "request_count": 320,
      "concurrency": 32,
      "prompt_tokens": 512,
      "max_tokens": 128,
      "output_tokens_target": 128,
      "temperature": 0.0,
      "timeout_seconds": 300
    },
    {
      "name": "m4_batching_c64_p512_o128",
      "analysis_group": "batching_capacity",
      "request_count": 640,
