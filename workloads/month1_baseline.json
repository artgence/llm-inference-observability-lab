{
  "description": "Month 1 baseline workload for a Qwen3.6 vLLM OpenAI-compatible chat endpoint.",
  "model": "Qwen/Qwen3.6-35B-A3B",
  "base_url": "http://localhost:8000",
  "api_key": "EMPTY",
  "runs": [
    {
      "name": "smoke_c1_prompt256_out128",
      "request_count": 5,
      "concurrency": 1,
      "prompt_words": 256,
      "max_tokens": 128,
      "temperature": 0.0,
      "timeout_seconds": 120,
      "extra_body": {
        "chat_template_kwargs": {
          "enable_thinking": false
        }
      }
    },
    {
      "name": "baseline_c4_prompt512_out128",
      "request_count": 20,
      "concurrency": 4,
      "prompt_words": 512,
      "max_tokens": 128,
      "temperature": 0.0,
      "timeout_seconds": 120,
      "extra_body": {
        "chat_template_kwargs": {
          "enable_thinking": false
        }
      }
    }
  ]
}
