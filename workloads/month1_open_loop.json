{
  "description": "Open-loop arrival-rate sweep for a Llama 3.1 8B FP8 vLLM endpoint.",
  "model": "neuralmagic/Meta-Llama-3.1-8B-Instruct-FP8",
  "base_url": "http://localhost:8000",
  "api_key": "EMPTY",
