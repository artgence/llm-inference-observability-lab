{
  "description": "Month 4 long-context capacity sweep below a 16,384-token server limit.",
  "model": "neuralmagic/Meta-Llama-3.1-8B-Instruct-FP8",
  "base_url": "http://localhost:8000",
  "api_key": "EMPTY",
  "max_model_len": 16384,
  "runs": [
    {
      "name": "m4_context_p2048_o128_rps2",
      "analysis_group": "context_capacity",
      "load_mode": "open_loop",
      "arrival_pattern": "steady",
      "arrival_rate_rps": 2,
      "request_count": 40,
      "max_in_flight": 128,
      "prompt_tokens": 2048,
      "max_tokens": 128,
      "output_tokens_target": 128,
      "temperature": 0.0,
      "timeout_seconds": 300
    },
    {
      "name": "m4_context_p8192_o128_rps2",
      "analysis_group": "context_capacity",
      "load_mode": "open_loop",
      "arrival_pattern": "steady",
      "arrival_rate_rps": 2,
      "request_count": 40,
      "max_in_flight": 128,
      "prompt_tokens": 8192,
      "max_tokens": 128,
      "output_tokens_target": 128,
      "temperature": 0.0,
      "timeout_seconds": 420
    },
    {
      "name": "m4_context_p15360_o128_rps2",
      "analysis_group": "context_capacity",
      "load_mode": "open_loop",
      "arrival_pattern": "steady",
      "arrival_rate_rps": 2,
      "request_count": 40,
      "max_in_flight": 128,
      "prompt_tokens": 15360,
      "max_tokens": 128,
      "output_tokens_target": 128,
      "temperature": 0.0,
      "timeout_seconds": 600
    }
  ]
}
