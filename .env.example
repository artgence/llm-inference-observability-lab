MODEL_ID=neuralmagic/Meta-Llama-3.1-8B-Instruct-FP8
SERVED_MODEL_NAME=neuralmagic/Meta-Llama-3.1-8B-Instruct-FP8
HF_TOKEN=hf_your_token_here
VLLM_BASE_URL=http://localhost:8000
OPENAI_API_KEY=EMPTY
PORT=8000
DTYPE=auto
MAX_MODEL_LEN=16384
TENSOR_PARALLEL_SIZE=1
LANGUAGE_MODEL_ONLY=false
GPU_MEMORY_UTILIZATION=0.90
# GPU_HOURLY_COST_USD=1.00

# Month 4 serving-knob experiments. Leave unset to use vLLM defaults.
# ENABLE_PREFIX_CACHING=true
# ENABLE_CHUNKED_PREFILL=true
# MAX_NUM_SEQS=64
# MAX_NUM_BATCHED_TOKENS=8192
# MAX_NUM_PARTIAL_PREFILLS=2
# MAX_LONG_PARTIAL_PREFILLS=1
# LONG_PREFILL_TOKEN_THRESHOLD=4096
# KV_CACHE_DTYPE=auto
# QUANTIZATION=fp8  # Leave unset when a pre-quantized checkpoint auto-detects it.
# CPU_OFFLOAD_GB=0
# VLLM_SERVER_CONFIG_LABEL=prefix_cache_on

# For full native Llama 3.1 context, validate GPU memory headroom and set:
# MAX_MODEL_LEN=131072
# TENSOR_PARALLEL_SIZE=1
